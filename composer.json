{
    "name": "axonc/filament-copyable-placeholder",
    "description": "This is my package filament-copyable-placeholder",
    "keywords": [
        "AxonC",
        "laravel",
        "filament-copyable-placeholder"
    ],
    "homepage": "https://github.com/axonc/filament-copyable-placeholder",
    "license": "MIT",
    "authors": [
        {
            "name": "Callum Axon",
            "email": "git@callumaxon.uk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.14.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AxonC\\FilamentCopyablePlaceholder\\": "src/",
            "AxonC\\FilamentCopyablePlaceholder\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AxonC\\FilamentCopyablePlaceholder\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AxonC\\FilamentCopyablePlaceholder\\FilamentCopyablePlaceholderServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
